{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/catalog/{**remainder}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/Catalog/{**remainder}"
          }
        ]
      },
      "basket-route": {
        "ClusterId": "basket-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/basket/{**remainder}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/Basket/{**remainder}"
          }
        ]
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**remainder}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/auth/{**remainder}"
          }
        ]
      },
      "ordering-route": {
        "ClusterId": "ordering-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/order/{**remainder}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/Order/{**remainder}"
          }
        ]
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "destination1": { "Address": "http://foodnet-catalog-api-1:8080/" },
          "destination2": { "Address": "http://foodnet-catalog-api-2:8080/" },
          "destination3": { "Address": "http://foodnet-catalog-api-3:8080/" }
        }
      },
      "basket-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "destination1": { "Address": "http://foodnet-basket-api-1:8080/" },
          "destination2": { "Address": "http://foodnet-basket-api-2:8080/" },
          "destination3": { "Address": "http://foodnet-basket-api-3:8080/" }
        }
      },
      "identity-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "destination1": { "Address": "http://foodnet-identity-api-1:8080/" },
          "destination2": { "Address": "http://foodnet-identity-api-2:8080/" },
          "destination3": { "Address": "http://foodnet-identity-api-3:8080/" }
        }
      },
      "ordering-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "destination1": { "Address": "http://foodnet-ordering-api-1:8080/" },
          "destination2": { "Address": "http://foodnet-ordering-api-2:8080/" },
          "destination3": { "Address": "http://foodnet-ordering-api-3:8080/" }
        }
      }
    }
  }
}
